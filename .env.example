# =============================================================
# BOOTSTRAP VARIABLES — required for the app to start at all.
# Copy this file to .env.live (or .env.staging) and fill these in.
# Generate secrets with: openssl rand -hex 32   (or -hex 64 for JWT)
# =============================================================
DOMAIN=trade.coinbidex.com
NODE_ENV=production
PLATFORM_MODE=live

DB_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# Image tag pulled from GHCR by docker-compose. CI sets this automatically
# during deploy; for a manual/local run "latest" is fine.
IMAGE_TAG=latest

# =============================================================
# RUNTIME VARIABLES — DO NOT put real values here.
# These are managed from the Admin → Settings → API Keys panel and are
# stored in the `SystemConfig` DB table, not in this file. The values below
# exist purely so the app doesn't crash on a completely empty first boot,
# and as a reference for which keys the admin panel expects.
#
# Once you set a key in the admin panel it overrides anything here.
# =============================================================
REFERRAL_WALLET_ADDRESS=
REFERRAL_FEE_BPS=30
SWAP_MARKUP_PCT=0.3
ONEINCH_API_KEY=
MOONPAY_PUBLISHABLE_KEY=
MOONPAY_SECRET_KEY=

# Swap widget — "internal" uses your own backend-routed swap (oneInchService,
# needs ONEINCH_API_KEY + Binance broker keys, which now require 1inch/
# Binance KYB approval to get). "1inch_embed" uses 1inch's embedded widget
# instead — non-custodial, executes from the USER'S own connected wallet
# (MetaMask etc), needs no liquidity or broker keys on your end at all.
# Switch from the admin Settings panel — no redeploy needed.
SWAP_WIDGET_PROVIDER=1inch_embed
# Your wallet address — 1inch routes a cut of every swap here automatically.
SWAP_REFERRER_ADDRESS=
# Referrer fee taken on top of the swap, in percent. 1inch caps this per
# chain (commonly up to 3%) — check current limits before raising it.
SWAP_REFERRER_FEE_PCT=0.5

# Stripe — powers invoice checkout for listings/ads (Admin Settings can
# override these too). Get keys at https://dashboard.stripe.com/apikeys
# and set up a webhook endpoint at https://dashboard.stripe.com/webhooks
# pointing to https://trade.coinbidex.com/api/v1/payments/stripe/webhook
# (event: checkout.session.completed) to get STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
BINANCE_BROKER_API_KEY=
BINANCE_BROKER_API_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
VITE_WALLETCONNECT_PROJECT_ID=
ETH_RPC_URL=https://cloudflare-eth.com
POLY_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Market data polling — see marketDataService.ts. Binance WebSocket is the
# primary live feed; this only controls the REST backfill/fallback cadence.
MARKET_DATA_POLL_INTERVAL_MS=300000
