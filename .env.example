# =============================================================
# BOOTSTRAP VARIABLES — required for the app to start at all.
# Copy this file to .env.live (or .env.staging) and fill these in.
# Generate secrets with: openssl rand -hex 32   (or -hex 64 for JWT)
# =============================================================
DOMAIN=trade.coinbidex.com
NODE_ENV=production
PLATFORM_MODE=live

DB_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# Image tag pulled from GHCR by docker-compose. CI sets this automatically
# during deploy; for a manual/local run "latest" is fine.
IMAGE_TAG=latest

# =============================================================
# RUNTIME VARIABLES — DO NOT put real values here.
# These are managed from the Admin → Settings → API Keys panel and are
# stored in the `SystemConfig` DB table, not in this file. The values below
# exist purely so the app doesn't crash on a completely empty first boot,
# and as a reference for which keys the admin panel expects.
#
# Once you set a key in the admin panel it overrides anything here.
# =============================================================
REFERRAL_WALLET_ADDRESS=
REFERRAL_FEE_BPS=30
SWAP_MARKUP_PCT=0.3
ONEINCH_API_KEY=
MOONPAY_PUBLISHABLE_KEY=
MOONPAY_SECRET_KEY=
BINANCE_BROKER_API_KEY=
BINANCE_BROKER_API_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
VITE_WALLETCONNECT_PROJECT_ID=
ETH_RPC_URL=https://cloudflare-eth.com
POLY_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Market data polling — see marketDataService.ts. Binance WebSocket is the
# primary live feed; this only controls the REST backfill/fallback cadence.
MARKET_DATA_POLL_INTERVAL_MS=300000
